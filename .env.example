# MicroClaw Environment Variables Template
# Copy this file to .env and fill in the actual values

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# MiniMax LLM Configuration
MINIMAX_API_KEY=your_minimax_api_key_here

# GitHub MCP Configuration
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# Dokploy Configuration
DOKPLOY_URL=http://dokploy.b2bscaler.com/api
DOKPLOY_API_KEY=your_dokploy_api_key_here

# PostgreSQL Connections
POSTGRES_PROD_URL=postgresql://user:password@host:port/database
POSTGRES_DEV_URL=postgresql://user:password@host:port/database

# SSH Configuration
SSH_HOST=your_ssh_host
SSH_USER=your_ssh_user
SSH_PRIVATE_KEY_PATH=/path/to/private/key
