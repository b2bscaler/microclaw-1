# MicroClaw Environment Variables
# Set these in your deployment environment (e.g., Dokploy)

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}

# MiniMax LLM Configuration
MINIMAX_API_KEY=${MINIMAX_API_KEY}

# OpenRouter (optional, for alternative models)
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}

# GitHub MCP Configuration
GITHUB_TOKEN=${GITHUB_TOKEN}

# Dokploy Configuration
DOKPLOY_URL=${DOKPLOY_URL}
DOKPLOY_API_KEY=${DOKPLOY_API_KEY}

# PostgreSQL Connections
POSTGRES_PROD_URL=${POSTGRES_PROD_URL}
POSTGRES_DEV_URL=${POSTGRES_DEV_URL}

# SSH Configuration
SSH_HOST=${SSH_HOST}
SSH_USER=${SSH_USER}
SSH_PRIVATE_KEY_PATH=${SSH_PRIVATE_KEY_PATH}
